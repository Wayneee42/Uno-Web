# Local and LAN settings
# auto means: use current page host with port 3001 (localhost or LAN IP only)
VITE_SERVER_URL=auto
# Allow both localhost and LAN origin in Socket.IO CORS
CLIENT_ORIGIN=http://localhost:3000,http://<HOST_IP>:3000

# Vercel + Render example
# Set these values in the hosting platform env settings instead of committing them.
# VITE_SERVER_URL=https://your-render-service.onrender.com
# CLIENT_ORIGIN=https://your-vercel-project.vercel.app,https://your-custom-domain.com
